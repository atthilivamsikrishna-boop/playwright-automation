{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",                               
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["UI/pages/*"],
      "@components/*": ["UI/components/*"],
      "@utils/*": ["utils/*"],
      "@data/*": ["test-data/*"]
    }
  },
  "include": ["UI", "tests", "utils", "test-data"]

  
}